#!/usr/bin/env python3
import sys
import os

# Add backend to path
backend_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, backend_dir)

try:
    # Try to import and run FastAPI backend
    print("Attempting to start FastAPI backend...")
    from app.main import app
    import uvicorn
    print("✅ FastAPI loaded successfully")
    uvicorn.run(app, host="0.0.0.0", port=8000)
except ImportError as e:
    print(f"⚠️ FastAPI not available: {e}")
    print("Starting Flask fallback...")
    
    # Fallback to Flask
    from flask import Flask, jsonify
    from flask_cors import CORS
    
    app = Flask(__name__)
    CORS(app)
    
    @app.route('/health')
    def health():
        return jsonify({
            'status': 'healthy',
            'service': 'flask-fallback',
            'message': 'FastAPI backend unavailable, using Flask fallback'
        })
    
    @app.route('/api/chat', methods=['POST'])
    def chat():
        return jsonify({
            'response': 'Backend is running in fallback mode. Install full dependencies for complete functionality.',
            'model': 'fallback'
        })
    
    print("Flask fallback server starting on port 8000...")
    app.run(host='0.0.0.0', port=8000, debug=False)
