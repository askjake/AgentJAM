def call_coverity_assist(messages):
    """Call Coverity Assist API for intelligent responses"""
    import requests
    
    try:
        headers = {
            'Authorization': f'Bearer {COVERITY_ASSIST_TOKEN}',
            'Content-Type': 'application/json'
        }
        
        payload = {
            'messages': messages,
            'model': 'claude-sonnet-4',
            'temperature': 0.7
        }
        
        logger.info(f"Calling Coverity Assist...")
        
        response = requests.post(
            COVERITY_ASSIST_URL,
            headers=headers,
            json=payload,
            timeout=30
        )
        
        if response.status_code == 200:
            data = response.json()
            if 'response' in data:
                return data['response']
            elif 'message' in data:
                return data['message']
            elif 'choices' in data and len(data['choices']) > 0:
                return data['choices'][0].get('message', {}).get('content', 'No response')
            else:
                return str(data)
        else:
            logger.error(f"Coverity Assist error: {response.status_code}")
            return None
            
    except Exception as e:
        logger.error(f"Error calling Coverity Assist: {e}")
        return None

def get_simple_response(message):
    """Fallback responses"""
    message_lower = message.lower()
    
    if 'hello' in message_lower or 'hi' in message_lower:
        return "Hello! I'm the DishChat agent running on agentpi001@172.16.235.90. How can I help you today?"
    elif 'help' in message_lower:
        return "I'm an AI assistant. I can answer questions and have conversations. Try asking me anything!"
    elif 'status' in message_lower:
        return "I'm online and running on agentpi001. Backend is operational!"
    elif 'who are you' in message_lower:
        return "I'm an AI assistant powered by Claude via Coverity Assist, running on agentpi001."
    else:
        return f"I'm processing your message: '{message}'. I'm running on agentpi001@172.16.235.90."

@app.route('/api/chat', methods=['POST', 'OPTIONS'])
def chat():
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        data = request.get_json()
        messages = data.get('messages', [])
        
        if not messages:
            return jsonify({"error": "No messages"}), 400
        
        last_message = None
        for msg in reversed(messages):
            if msg.get('role') == 'user':
                last_message = msg.get('content', '')
                break
        
        if not last_message:
            return jsonify({"error": "No user message"}), 400
        
        logger.info(f"User: {last_message[:100]}")
        
        # Try Coverity Assist
        response_text = call_coverity_assist(messages)
        
        # Fallback to simple if failed
        if not response_text:
            logger.warning("Using fallback response")
            response_text = get_simple_response(last_message)
        
        return jsonify({
            'response': response_text,
            'model': 'coverity-assist',
            'timestamp': datetime.now().isoformat(),
            'device': 'agentpi001@172.16.235.90'
        })
        
    except Exception as e:
        logger.error(f"Error: {e}")
        return jsonify({
            'error': str(e),
            'response': "Sorry, I encountered an error."
        }), 500

