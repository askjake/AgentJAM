
'use client';

import { useState, useEffect } from 'react';
import { Card, Button, Select, Input, Form, message, Spin, Alert, Space, Typography, Divider } from 'antd';
import { PlusOutlined, DeleteOutlined, CheckCircleOutlined } from '@ant-design/icons';

const { Title, Text, Paragraph } = Typography;
const { Option } = Select;

interface LLMProvider {
  id: number;
  name: string;
  display_name: string;
  provider_type: string;
  description: string;
  requires_api_key: boolean;
  requires_region: boolean;
}

interface LLMModel {
  id: number;
  provider_id: number;
  model_name: string;
  model_id: string;
  display_name: string;
  description: string;
  context_length: number;
}

interface UserLLMConfig {
  id?: number;
  provider_id: number;
  model_id: number;
  api_key?: string;
  region?: string;
  is_active: boolean;
}

export default function LLMSettingsPage() {
  const [providers, setProviders] = useState<LLMProvider[]>([]);
  const [models, setModels] = useState<LLMModel[]>([]);
  const [userConfigs, setUserConfigs] = useState<UserLLMConfig[]>([]);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [form] = Form.useForm();

  const apiBaseUrl = process.env.NEXT_PUBLIC_API_BASE_URL || '';

  useEffect(() => {
    fetchData();
  }, []);

  const fetchData = async () => {
    try {
      setLoading(true);
      
      // Fetch providers
      const providersRes = await fetch(`${apiBaseUrl}/rest/api/v1/llm/providers`);
      if (providersRes.ok) {
        const providersData = await providersRes.json();
        setProviders(providersData);
      }

      // Fetch models
      const modelsRes = await fetch(`${apiBaseUrl}/rest/api/v1/llm/models`);
      if (modelsRes.ok) {
        const modelsData = await modelsRes.json();
        setModels(modelsData);
      }

      // Fetch user configs
      const configsRes = await fetch(`${apiBaseUrl}/rest/api/v1/llm/my-configs`);
      if (configsRes.ok) {
        const configsData = await configsRes.json();
        setUserConfigs(configsData);
      }

    } catch (error) {
      console.error('Failed to fetch LLM data:', error);
      message.error('Failed to load LLM settings');
    } finally {
      setLoading(false);
    }
  };

  const handleSaveConfig = async (values: any) => {
    try {
      setSaving(true);
      
      const config = {
        provider_id: values.provider_id,
        model_id: values.model_id,
        api_key: values.api_key,
        region: values.region,
        is_active: true
      };

      const response = await fetch(`${apiBaseUrl}/rest/api/v1/llm/select`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(config),
      });

      if (response.ok) {
        message.success('LLM configuration saved successfully!');
        form.resetFields();
        fetchData(); // Refresh data
      } else {
        const error = await response.json();
        message.error(`Failed to save: ${error.detail || 'Unknown error'}`);
      }
    } catch (error) {
      console.error('Failed to save LLM config:', error);
      message.error('Failed to save configuration');
    } finally {
      setSaving(false);
    }
  };

  const getProviderModels = (providerId: number) => {
    return models.filter(m => m.provider_id === providerId);
  };

  const getProviderById = (providerId: number) => {
    return providers.find(p => p.id === providerId);
  };

  if (loading) {
    return (
      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: '400px' }}>
        <Spin size="large" tip="Loading LLM settings..." />
      </div>
    );
  }

  return (
    <div style={{ padding: '24px', maxWidth: '1200px', margin: '0 auto' }}>
      <Title level={2}>LLM Configuration</Title>
      <Paragraph>
        Configure your AI language model providers. You can add multiple providers and models,
        including Anthropic Claude, OpenAI GPT, AWS Bedrock, and local Ollama models.
      </Paragraph>

      <Alert
        message="Available Providers"
        description={`${providers.length} providers available: ${providers.map(p => p.display_name).join(', ')}`}
        type="info"
        showIcon
        style={{ marginBottom: '24px' }}
      />

      <Card title="Add New LLM Configuration" style={{ marginBottom: '24px' }}>
        <Form
          form={form}
          layout="vertical"
          onFinish={handleSaveConfig}
        >
          <Form.Item
            label="Provider"
            name="provider_id"
            rules={[{ required: true, message: 'Please select a provider' }]}
          >
            <Select
              placeholder="Select an LLM provider"
              size="large"
              onChange={() => form.setFieldsValue({ model_id: undefined })}
            >
              {providers.map(provider => (
                <Option key={provider.id} value={provider.id}>
                  <Space direction="vertical" size={0}>
                    <Text strong>{provider.display_name}</Text>
                    <Text type="secondary" style={{ fontSize: '12px' }}>
                      {provider.description}
                    </Text>
                  </Space>
                </Option>
              ))}
            </Select>
          </Form.Item>

          <Form.Item
            noStyle
            shouldUpdate={(prevValues, currentValues) => 
              prevValues.provider_id !== currentValues.provider_id
            }
          >
            {({ getFieldValue }) => {
              const selectedProviderId = getFieldValue('provider_id');
              const availableModels = selectedProviderId ? getProviderModels(selectedProviderId) : [];
              const selectedProvider = selectedProviderId ? getProviderById(selectedProviderId) : null;

              return (
                <>
                  {availableModels.length > 0 && (
                    <Form.Item
                      label="Model"
                      name="model_id"
                      rules={[{ required: true, message: 'Please select a model' }]}
                    >
                      <Select placeholder="Select a model" size="large">
                        {availableModels.map(model => (
                          <Option key={model.id} value={model.id}>
                            <Space direction="vertical" size={0}>
                              <Text strong>{model.display_name || model.model_name}</Text>
                              <Text type="secondary" style={{ fontSize: '12px' }}>
                                {model.description} • Context: {model.context_length.toLocaleString()} tokens
                              </Text>
                            </Space>
                          </Option>
                        ))}
                      </Select>
                    </Form.Item>
                  )}

                  {selectedProvider?.requires_api_key && (
                    <Form.Item
                      label="API Key"
                      name="api_key"
                      rules={[{ required: true, message: 'Please enter your API key' }]}
                    >
                      <Input.Password
                        placeholder="Enter your API key"
                        size="large"
                      />
                    </Form.Item>
                  )}

                  {selectedProvider?.requires_region && (
                    <Form.Item
                      label="AWS Region"
                      name="region"
                      rules={[{ required: true, message: 'Please enter AWS region' }]}
                    >
                      <Input
                        placeholder="e.g., us-west-2"
                        size="large"
                      />
                    </Form.Item>
                  )}
                </>
              );
            }}
          </Form.Item>

          <Form.Item>
            <Button
              type="primary"
              htmlType="submit"
              loading={saving}
              icon={<PlusOutlined />}
              size="large"
            >
              Add Configuration
            </Button>
          </Form.Item>
        </Form>
      </Card>

      <Card title="Your LLM Configurations">
        {userConfigs.length === 0 ? (
          <Alert
            message="No configurations yet"
            description="Add your first LLM configuration above to get started."
            type="warning"
            showIcon
          />
        ) : (
          <Space direction="vertical" size="middle" style={{ width: '100%' }}>
            {userConfigs.map(config => {
              const provider = getProviderById(config.provider_id);
              const model = models.find(m => m.id === config.model_id);
              
              return (
                <Card
                  key={config.id}
                  size="small"
                  extra={
                    config.is_active && (
                      <CheckCircleOutlined style={{ color: '#52c41a', fontSize: '18px' }} />
                    )
                  }
                >
                  <Space direction="vertical" size="small" style={{ width: '100%' }}>
                    <Text strong>{provider?.display_name}</Text>
                    <Text>{model?.display_name || model?.model_name}</Text>
                    {config.api_key && (
                      <Text type="secondary">API Key: ••••••••{config.api_key.slice(-4)}</Text>
                    )}
                    {config.is_active && (
                      <Text type="success">✓ Active</Text>
                    )}
                  </Space>
                </Card>
              );
            })}
          </Space>
        )}
      </Card>

      <Divider />

      <Card title="Provider Information" style={{ marginTop: '24px' }}>
        <Space direction="vertical" size="large" style={{ width: '100%' }}>
          {providers.map(provider => (
            <div key={provider.id}>
              <Title level={5}>{provider.display_name}</Title>
              <Paragraph>{provider.description}</Paragraph>
              <Text type="secondary">
                Type: {provider.provider_type} • 
                {provider.requires_api_key && ' Requires API Key'} •
                {provider.requires_region && ' Requires Region'} •
                Models: {getProviderModels(provider.id).length}
              </Text>
            </div>
          ))}
        </Space>
      </Card>
    </div>
  );
}
