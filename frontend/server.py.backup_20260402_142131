def health():
    return {'status': 'healthy', 'service': 'enhanced-frontend', 'device': 'agentpi003'}

if __name__ == '__main__':
    print("Starting Enhanced DishChat Frontend on port 3000...")
    app.run(host='0.0.0.0', port=3000, debug=False)
