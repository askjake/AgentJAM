function loadActivityLog() {
    const logBody = document.getElementById('activity-log-body');
    if (!logBody) return;
    
    const mockLogs = [
        { time: '14:32:15', action: 'Search Query', tool: 'internal_search', user: 'user@dish.com', status: 'success', duration: '1.2s' },
        { time: '14:30:08', action: 'Cluster Inspection', tool: 'cluster_inspect', user: 'user@dish.com', status: 'success', duration: '2.5s' },
        { time: '14:28:42', action: 'Python Execution', tool: 'agent_run_python', user: 'user@dish.com', status: 'success', duration: '3.1s' },
        { time: '14:25:19', action: 'Viewership Query', tool: 'query_viewership', user: 'user@dish.com', status: 'success', duration: '1.8s' },
        { time: '14:22:33', action: 'Shell Command', tool: 'agent_run_shell', user: 'user@dish.com', status: 'success', duration: '0.9s' }
    ];
    
    logBody.innerHTML = mockLogs.map(log => `
        <tr>
            <td>${log.time}</td>
            <td>${log.action}</td>
            <td><code>${log.tool}</code></td>
            <td>${log.user}</td>
            <td><span class="status-success">✓ ${log.status}</span></td>
            <td>${log.duration}</td>
        </tr>
    `).join('');
}

// ==========================================================================
// Documentation
// ==========================================================================

function initializeDocs() {
    document.querySelectorAll('.docs-nav li').forEach(item => {
        item.addEventListener('click', () => {
            const docType = item.getAttribute('data-doc');
            loadDocumentation(docType);
            
            // Update active state
            document.querySelectorAll('.docs-nav li').forEach(i => i.classList.remove('active'));
            item.classList.add('active');
        });
    });
    
    document.querySelectorAll('.doc-card').forEach(card => {
        card.addEventListener('click', (e) => {
            e.preventDefault();
            const docType = card.getAttribute('data-doc');
            switchView('docs');
            loadDocumentation(docType);
        });
    });
    
    document.getElementById('open-external')?.addEventListener('click', () => {
        alert('Opening in external editor...');
    });
}

function loadDocumentation(docType) {
    console.log(`Loading documentation: ${docType}`);
    
    const docTitle = document.getElementById('doc-title');
    const docBody = document.getElementById('doc-body');
    
    const docInfo = {
        coverity: {
            title: 'Coverity Assist API Documentation',
            content: `# Coverity Assist API Documentation

## Overview
Multi-model LLM API supporting Claude Sonnet 4, Haiku 4.5, and Opus 4.

## Key Features
- Multiple model support
- Authentication & security
- Web search integration
- Workflow automation

## Endpoints
- /api/chat - Main chat endpoint
- /api/search - Search functionality
- /api/models - Available models

*Full documentation available at: ${CONFIG.DOCS_PATH}${CONFIG.DOCS.coverity}*`
        },
        rca: {
            title: 'RCA Methodology',
            content: `# Root Cause Analysis Methodology

## Process
1. Incident identification
2. Data collection
3. Timeline reconstruction
4. Root cause determination
5. Solution implementation

## Best Practices
- Document everything
- Use structured templates
- Follow golden config
- Verify solutions

*Full documentation available at: ${CONFIG.DOCS_PATH}${CONFIG.DOCS.rca}*`
        },
        jira: {
            title: 'JIRA Ticket Creation',
            content: `# JIRA Ticket Creation Guide

## Ticket Types
- Bug reports
- Feature requests
- Improvements
- Tasks

## Required Fields
- Summary
- Description
- Priority
- Component
- Assignee

*Full documentation available at: ${CONFIG.DOCS_PATH}${CONFIG.DOCS.jira}*`
        },
        reports: {
            title: 'Report Writing Methodology',
            content: `# Report Writing Standards

## Structure
1. Executive Summary
2. Technical Details
3. Analysis
4. Recommendations
5. Conclusion

## Style Guidelines
- Clear and concise
- Technical accuracy
- Professional tone
- Well-organized

*Full documentation available at: ${CONFIG.DOCS_PATH}${CONFIG.DOCS.reports}*`
        }
    };
    
    const doc = docInfo[docType];
    if (doc) {
        docTitle.textContent = doc.title;
        // In production, this would use marked.js to render markdown
        docBody.innerHTML = `<pre>${doc.content}</pre>`;
    }
}

