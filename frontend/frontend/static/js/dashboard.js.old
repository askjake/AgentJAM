// ==========================================================================
// Configuration
// ==========================================================================

const CONFIG = {
    API_BASE_URL: 'http://10.73.184.59:8000',
    WS_URL: 'ws://localhost:8000/ws',
    DOCS_PATH: '/home/montjac/Jakes-agent/docs/',
    DOCS: {
        coverity: 'COVERITY_ASSIST_API.md',
        rca: 'RCA_GOLDEN_CONFIG.md',
        jira: 'JIRA_TICKET_CREATION_GOLDEN_CONFIG.md',
        reports: 'REPORT_METHODOLOGY.md'
    }
};

// ==========================================================================
// State Management
// ==========================================================================

const state = {
    currentView: 'overview',
    currentChat: null,
    activeTool: null,
    uptime: 0,
    stats: {
        conversations: 0,
        success: 0,
        responseTime: 2.3,
        toolInvocations: 0
    }
};

// ==========================================================================
// Initialization
// ==========================================================================

document.addEventListener('DOMContentLoaded', () => {
    console.log('🤖 DISH Chat Agent Dashboard Initializing...');
    
    initializeNavigation();
    initializeChat();
    initializeTools();
    initializeAnalytics();
    initializeDocs();
    initializeSettings();
    startUptimeCounter();
    loadInitialData();
    
    console.log('✅ Dashboard Initialized Successfully');
});

// ==========================================================================
// Navigation System
// ==========================================================================

function initializeNavigation() {
    const navButtons = document.querySelectorAll('.nav-btn');
    
    navButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const view = btn.getAttribute('data-view');
            switchView(view);
            
            // Update active button
            navButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        });
    });
    
    // Sidebar tool navigation
    document.querySelectorAll('.tool-item').forEach(item => {
        item.addEventListener('click', () => {
            switchView('tools');
            const toolType = item.getAttribute('data-tool');
            scrollToToolCategory(toolType);
        });
    });
}

function switchView(viewName) {
    console.log(`Switching to view: ${viewName}`);
    
    // Hide all views
    document.querySelectorAll('.content-view').forEach(view => {
        view.classList.remove('active');
    });
    
    // Show selected view
    const targetView = document.getElementById(`${viewName}-view`);
    if (targetView) {
        targetView.classList.add('active');
        state.currentView = viewName;
    }
}

function scrollToToolCategory(category) {
    // Implementation for scrolling to specific tool category
    console.log(`Scrolling to tool category: ${category}`);
}

// ==========================================================================
// Chat Interface
// ==========================================================================

function initializeChat() {
    const chatInput = document.getElementById('chat-input');
    const sendButton = document.getElementById('send-message');
    const newChatBtn = document.getElementById('new-chat');
    const exportBtn = document.getElementById('export-chat');
    
    // Auto-resize textarea
    chatInput?.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
    });
    
    // Send message on Enter (not Shift+Enter)
    chatInput?.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
    
    sendButton?.addEventListener('click', sendMessage);
    newChatBtn?.addEventListener('click', createNewChat);
    exportBtn?.addEventListener('click', exportChat);
    
    // Quick actions
    document.querySelectorAll('.quick-action').forEach(btn => {
        btn.addEventListener('click', () => {
            const action = btn.getAttribute('data-action');
            handleQuickAction(action);
        });
    });
    
    // Voice input (placeholder)
    document.getElementById('voice-input')?.addEventListener('click', () => {
        alert('Voice input feature coming soon!');
    });
    
    // File attachment (placeholder)
    document.getElementById('attach-file')?.addEventListener('click', () => {
        alert('File attachment feature coming soon!');
    });
}

function sendMessage() {
    const input = document.getElementById('chat-input');
    const message = input.value.trim();
    
    if (!message) return;
    
    console.log('Sending message:', message);
    
    // Add user message to chat
    addMessageToChat('user', message);
    
    // Clear input
    input.value = '';
    input.style.height = 'auto';
    
    // Show typing indicator
    showTypingIndicator();
    
    // Simulate API call
    setTimeout(() => {
        hideTypingIndicator();
        const response = generateMockResponse(message);
        addMessageToChat('agent', response);
    }, 1500);
    
    // Update stats
    state.stats.conversations++;
    updateStatsDisplay();
}

function addMessageToChat(sender, content) {
    const messagesContainer = document.getElementById('chat-messages');
    const welcomeMessage = messagesContainer.querySelector('.welcome-message');
    
    if (welcomeMessage) {
        welcomeMessage.style.display = 'none';
    }
    
    const messageDiv = document.createElement('div');
    messageDiv.className = `chat-message ${sender}-message`;
    messageDiv.innerHTML = `
        <div class="message-avatar">
            <i class="fas fa-${sender === 'user' ? 'user' : 'robot'}"></i>
        </div>
        <div class="message-content">
            <div class="message-header">
                <strong>${sender === 'user' ? 'You' : 'Agent'}</strong>
                <span class="message-time">${new Date().toLocaleTimeString()}</span>
            </div>
            <div class="message-text">${content}</div>
        </div>
    `;
    
    messagesContainer.appendChild(messageDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

function showTypingIndicator() {
    document.querySelector('.typing-indicator').style.display = 'flex';
}

function hideTypingIndicator() {
    document.querySelector('.typing-indicator').style.display = 'none';
}

function generateMockResponse(userMessage) {
    const responses = {
        'hello': 'Hello! I'm the DISH Chat Agent. How can I assist you today?',
        'help': 'I can help you with:
• Searching documentation
• Kubernetes cluster inspection
• Viewership data queries
• Code execution
• And much more!',
        'search': 'I can search through internal DISH documentation, public web, and the Netra log system. What would you like to search for?',
        'cluster': 'I can inspect your Kubernetes cluster. Would you like me to list pods, check deployments, or view node status?',
        'default': 'I understand. Let me help you with that. Could you provide more details?'
    };
    
    const lowerMessage = userMessage.toLowerCase();
    
    for (const [key, response] of Object.entries(responses)) {
        if (lowerMessage.includes(key)) {
            return response;
        }
    }
    
    return responses.default;
}

function createNewChat() {
    console.log('Creating new chat');
    const messagesContainer = document.getElementById('chat-messages');
    messagesContainer.innerHTML = `
        <div class="welcome-message">
            <i class="fas fa-robot"></i>
            <h3>Welcome to DISH Chat Agent</h3>
            <p>I'm here to help you with infrastructure, development, analytics, and more!</p>
            <div class="quick-actions">
                <button class="quick-action" data-action="search">
                    <i class="fas fa-search"></i> Search Documentation
                </button>
                <button class="quick-action" data-action="cluster">
                    <i class="fas fa-server"></i> Check Cluster Status
                </button>
                <button class="quick-action" data-action="viewership">
                    <i class="fas fa-chart-line"></i> Query Viewership
                </button>
                <button class="quick-action" data-action="help">
                    <i class="fas fa-question-circle"></i> Show Capabilities
                </button>
            </div>
        </div>
    `;
    
    // Re-attach event listeners
    document.querySelectorAll('.quick-action').forEach(btn => {
        btn.addEventListener('click', () => {
            const action = btn.getAttribute('data-action');
            handleQuickAction(action);
        });
    });
}

function exportChat() {
    console.log('Exporting chat');
    alert('Chat export feature coming soon!');
}

function handleQuickAction(action) {
    const actions = {
        'search': 'Can you help me search for documentation?',
        'cluster': 'Can you check the cluster status?',
        'viewership': 'Can you show me viewership data?',
        'help': 'What can you help me with?'
    };
    
    const message = actions[action] || 'Help';
    document.getElementById('chat-input').value = message;
    sendMessage();
}

// ==========================================================================
// Tools System
// ==========================================================================

function initializeTools() {
    document.querySelectorAll('.btn-test-tool').forEach(btn => {
        btn.addEventListener('click', () => {
            const tool = btn.getAttribute('data-tool');
            openToolTestModal(tool);
        });
    });
    
    // Modal controls
    document.querySelector('.modal-close')?.addEventListener('click', closeToolModal);
    document.getElementById('execute-tool')?.addEventListener('click', executeToolTest);
}

function openToolTestModal(toolName) {
    console.log(`Opening test modal for tool: ${toolName}`);
    
    const modal = document.getElementById('tool-test-modal');
    const toolNameSpan = document.getElementById('modal-tool-name');
    const parametersDiv = document.getElementById('tool-parameters');
    
    toolNameSpan.textContent = toolName;
    state.activeTool = toolName;
    
    // Generate parameter inputs based on tool
    parametersDiv.innerHTML = generateToolParameters(toolName);
    
    modal.classList.add('active');
}

function closeToolModal() {
    document.getElementById('tool-test-modal').classList.remove('active');
    state.activeTool = null;
}

function generateToolParameters(toolName) {
    const parameters = {
        'internal_search': `
            <div class="parameter-group">
                <label>Query</label>
                <input type="text" id="param-query" placeholder="Enter search query" />
            </div>
            <div class="parameter-group">
                <label>Max Results</label>
                <input type="number" id="param-top-k" value="5" min="1" max="10" />
            </div>
        `,
        'cluster_inspect': `
            <div class="parameter-group">
                <label>Task</label>
                <select id="param-task">
                    <option>list sentry pods</option>
                    <option>list all pods</option>
                    <option>list nodes</option>
                    <option>list deployments</option>
                    <option>list services</option>
                </select>
            </div>
        `,
        'agent_run_shell': `
            <div class="parameter-group">
                <label>Command</label>
                <input type="text" id="param-command" placeholder="kubectl get pods" />
            </div>
            <div class="alert">
                <i class="fas fa-shield-alt"></i>
                Only read-only kubectl commands are allowed
            </div>
        `,
        'query_viewership': `
            <div class="parameter-group">
                <label>Service UIDs (comma-separated)</label>
                <input type="text" id="param-services" placeholder="123,456,789" />
            </div>
            <div class="parameter-group">
                <label>From Epoch (UTC)</label>
                <input type="number" id="param-from" placeholder="1640000000" />
            </div>
            <div class="parameter-group">
                <label>To Epoch (UTC)</label>
                <input type="number" id="param-to" placeholder="1640086400" />
            </div>
        `
    };
    
    return parameters[toolName] || '<p>No parameters required</p>';
}

function executeToolTest() {
    console.log(`Executing tool: ${state.activeTool}`);
    
    const resultsDiv = document.getElementById('tool-results');
    resultsDiv.textContent = 'Executing tool...';
    
    // Simulate tool execution
    setTimeout(() => {
        const mockResult = {
            success: true,
            tool: state.activeTool,
            timestamp: new Date().toISOString(),
            results: `Mock results for ${state.activeTool}\n\nTool executed successfully!`
        };
        
        resultsDiv.textContent = JSON.stringify(mockResult, null, 2);
        
        // Update stats
        state.stats.toolInvocations++;
        updateStatsDisplay();
    }, 1000);
}

