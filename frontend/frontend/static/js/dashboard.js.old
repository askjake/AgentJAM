    console.log('Settings initialized');
}

// ==========================================================================
// Data Loading & Updates
// ==========================================================================

function loadInitialData() {
    // Load initial stats
    state.stats = {
        conversations: 1247,
        success: 1228,
        responseTime: 2.3,
        toolInvocations: 4687
    };
    
    updateStatsDisplay();
    updateActivityFeed();
}

function updateStatsDisplay() {
    document.getElementById('stat-conversations').textContent = state.stats.conversations.toLocaleString();
    document.getElementById('stat-success').textContent = state.stats.success.toLocaleString();
    document.getElementById('stat-response').textContent = state.stats.responseTime + 's';
    document.getElementById('stat-tools').textContent = state.stats.toolInvocations.toLocaleString();
    
    document.getElementById('active-chats').textContent = Math.floor(Math.random() * 10);
    document.getElementById('total-sessions').textContent = state.stats.conversations;
}

function updateActivityFeed() {
    const feed = document.getElementById('recent-activity');
    if (!feed) return;
    
    feed.innerHTML = `
        <div class="activity-item">
            <i class="fas fa-search"></i>
            <span>Internal search executed</span>
            <span class="time">2m ago</span>
        </div>
        <div class="activity-item">
            <i class="fas fa-server"></i>
            <span>Cluster inspection completed</span>
            <span class="time">5m ago</span>
        </div>
        <div class="activity-item">
            <i class="fas fa-code"></i>
            <span>Python script executed</span>
            <span class="time">8m ago</span>
        </div>
    `;
}

function startUptimeCounter() {
    setInterval(() => {
        state.uptime++;
        const days = Math.floor(state.uptime / 86400);
        const hours = Math.floor((state.uptime % 86400) / 3600);
        const minutes = Math.floor((state.uptime % 3600) / 60);
        
        document.getElementById('uptime').textContent = `${days}d ${hours}h ${minutes}m`;
    }, 60000); // Update every minute
}

// ==========================================================================
// Utility Functions
// ==========================================================================

function formatTime(date) {
    return new Date(date).toLocaleTimeString();
}

function formatDate(date) {
    return new Date(date).toLocaleDateString();
}

function showNotification(message, type = 'info') {
    console.log(`[${type.toUpperCase()}] ${message}`);
    // In production, this would show a toast notification
}

// ==========================================================================
// Error Handling
// ==========================================================================

window.addEventListener('error', (event) => {
    console.error('Global error:', event.error);
    showNotification('An error occurred. Please check the console.', 'error');
});

console.log('🚀 DISH Chat Agent Dashboard JavaScript Loaded');
