


/* ========================================
   CUSTOM TOOLS MANAGEMENT STYLES (IMPROVED)
   Matches dashboard design system
   ======================================== */

/* Custom Tools Section - Main Container */
#custom-tools-section {
    padding: var(--spacing-xl);
    max-width: 1600px;
    margin: 0 auto;
}

/* Header Section */
.custom-tools-header {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
}

.custom-tools-header h3 {
    color: var(--text-primary);
    font-size: 28px;
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
}

.custom-tools-header h3 i {
    color: var(--primary-color);
    font-size: 24px;
}

.custom-tools-header p {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.5;
    margin-top: var(--spacing-sm);
}

/* Action Bar */
.custom-tools-actions {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
    align-items: center;
    flex-wrap: wrap;
    background: var(--card-bg);
    padding: var(--spacing-md);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
}

.tools-view-toggle {
    display: flex;
    gap: var(--spacing-xs);
    margin-left: auto;
    background: var(--dark-bg);
    padding: 4px;
    border-radius: var(--radius-md);
}

.view-toggle {
    padding: 8px 14px;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
    color: var(--text-secondary);
    font-size: 16px;
}

.view-toggle:hover {
    background: var(--hover-bg);
    color: var(--text-primary);
}

.view-toggle.active {
    background: var(--primary-color);
    color: white;
}

.tools-search-input {
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--dark-bg);
    color: var(--text-primary);
    font-size: 14px;
    min-width: 250px;
    transition: all var(--transition-fast);
}

.tools-search-input:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
}

.tools-search-input::placeholder {
    color: var(--text-secondary);
}

/* Stats Cards */
.tools-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
}

.stat-card {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    color: white;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-normal);
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.stat-card i {
    font-size: 36px;
    opacity: 0.9;
}

.stat-value {
    display: block;
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
}

.stat-label {
    display: block;
    font-size: 13px;
    opacity: 0.9;
    margin-top: 4px;
    font-weight: 500;
}

/* Tools Grid */
.custom-tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-lg);
}

.custom-tools-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

/* Tool Card */
.tool-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    transition: all var(--transition-normal);
    cursor: pointer;
}

.tool-card:hover {
    border-color: var(--primary-color);
    box-shadow: 0 8px 24px rgba(0, 102, 204, 0.2);
    transform: translateY(-4px);
}

.tool-card-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: var(--spacing-md);
}

.tool-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    box-shadow: var(--shadow-sm);
}

.tool-status-badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.tool-status-badge.active {
    background: var(--success-color);
    color: white;
}

.tool-status-badge.inactive {
    background: var(--danger-color);
    color: white;
}

.tool-card-body h4 {
    color: var(--text-primary);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
}

.tool-card-body p {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: var(--spacing-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.tool-meta {
    display: flex;
    gap: var(--spacing-md);
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-md);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--border-color);
}

.tool-meta i {
    margin-right: 4px;
}

.tool-card-actions {
    display: flex;
    gap: var(--spacing-sm);
}

.tool-action-btn {
    flex: 1;
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    background: var(--dark-bg);
    color: var(--text-primary);
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.tool-action-btn:hover {
    background: var(--hover-bg);
    border-color: var(--primary-color);
}

.tool-action-btn.primary {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
}

.tool-action-btn.primary:hover {
    background: #0052a3;
    box-shadow: var(--shadow-md);
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: var(--spacing-xl) * 2;
    grid-column: 1 / -1;
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    border: 2px dashed var(--border-color);
}

.empty-state i {
    font-size: 72px;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    opacity: 0.5;
}

.empty-state h4 {
    color: var(--text-primary);
    font-size: 22px;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
}

.empty-state p {
    color: var(--text-secondary);
    font-size: 15px;
    margin-bottom: var(--spacing-lg);
}

/* Modal Styles */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: var(--spacing-lg);
}

.modal-content {
    background: var(--card-bg);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-color);
}

.modal-large {
    max-width: 900px;
}

.modal-header {
    padding: var(--spacing-lg) var(--spacing-xl);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--dark-bg);
}

.modal-header h3 {
    color: var(--text-primary);
    font-size: 22px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
}

.modal-header h3 i {
    color: var(--primary-color);
}

.modal-close {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 28px;
    cursor: pointer;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
}

.modal-close:hover {
    background: var(--hover-bg);
    color: var(--text-primary);
}

.modal-body {
    padding: var(--spacing-xl);
    overflow-y: auto;
    flex: 1;
}

/* Creation Tabs */
.creation-tabs {
    display: flex;
    gap: 0;
    margin-bottom: var(--spacing-xl);
    border-bottom: 2px solid var(--border-color);
    background: var(--dark-bg);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    padding: 0 var(--spacing-md);
}

.creation-tab {
    padding: var(--spacing-md) var(--spacing-lg);
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    transition: all var(--transition-fast);
    position: relative;
    margin-bottom: -2px;
}

.creation-tab:hover {
    color: var(--text-primary);
    background: var(--hover-bg);
}

.creation-tab.active {
    color: var(--primary-color);
    border-bottom-color: var(--primary-color);
}

.creation-tab i {
    margin-right: var(--spacing-sm);
}

.creation-panel {
    display: none;
}

.creation-panel.active {
    display: block;
}

/* Form Styles */
.form-group {
    margin-bottom: var(--spacing-lg);
}

.form-group label {
    display: block;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
    font-size: 14px;
}

.form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 14px;
    font-family: inherit;
    background: var(--dark-bg);
    color: var(--text-primary);
    transition: all var(--transition-fast);
}

.form-input:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
}

.form-input::placeholder {
    color: var(--text-secondary);
}

.code-editor {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.6;
    background: var(--dark-bg);
    resize: vertical;
}

.form-group small {
    display: block;
    color: var(--text-secondary);
    font-size: 12px;
    margin-top: var(--spacing-xs);
    font-style: italic;
}

.form-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: flex-end;
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--border-color);
}

/* Template Grid */
.template-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
}

.template-card {
    border: 2px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    text-align: center;
    transition: all var(--transition-normal);
    cursor: pointer;
    background: var(--card-bg);
}

.template-card:hover {
    border-color: var(--primary-color);
    box-shadow: 0 8px 16px rgba(0, 102, 204, 0.2);
    transform: translateY(-4px);
}

.template-card i {
    font-size: 42px;
    color: var(--primary-color);
    margin-bottom: var(--spacing-md);
}

.template-card h4 {
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
}

.template-card p {
    color: var(--text-secondary);
    font-size: 13px;
    line-height: 1.4;
    margin-bottom: var(--spacing-md);
}

.select-template-btn {
    width: 100%;
}

/* Code Preview */
.code-preview {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', monospace;
    font-size: 13px;
    line-height: 1.6;
    max-height: 500px;
    border: 1px solid var(--border-color);
}

/* Tool Details */
.tool-details-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
}

.tool-info-section {
    background: var(--dark-bg);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
}

.tool-info-row {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
}

.tool-info-row:last-child {
    margin-bottom: 0;
}

.info-label {
    font-weight: 600;
    color: var(--text-secondary);
    min-width: 140px;
    font-size: 14px;
}

.info-value {
    color: var(--text-primary);
    font-size: 14px;
}

.status-badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
}

.status-badge.active {
    background: var(--success-color);
    color: white;
}

.status-badge.inactive {
    background: var(--danger-color);
    color: white;
}

.tool-description-section h4,
.tool-code-section h4,
.tool-test-section h4 {
    color: var(--text-primary);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--border-color);
}

.test-results {
    margin-top: var(--spacing-md);
    background: var(--dark-bg);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--primary-color);
}

.test-results h5 {
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
    font-size: 14px;
}

#test-output {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: var(--spacing-md);
    border-radius: var(--radius-sm);
    font-family: monospace;
    font-size: 13px;
    overflow-x: auto;
    max-height: 400px;
    border: 1px solid var(--border-color);
}

/* Button Styles - Updated to match theme */
.btn-primary {
    background: var(--primary-color);
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.btn-primary:hover {
    background: #0052a3;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
}

.btn-primary i {
    font-size: 14px;
}

.btn-secondary {
    background: var(--card-bg);
    color: var(--text-primary);
    padding: 10px 20px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.btn-secondary:hover {
    background: var(--hover-bg);
    border-color: var(--primary-color);
}

.btn-danger {
    background: var(--danger-color);
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.btn-danger:hover {
    background: #cc2e24;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
}

/* Loading State */
.loading-spinner {
    display: inline-block;
    width: 18px;
    height: 18px;
    border: 3px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Responsive Design */
@media (max-width: 1024px) {
    #custom-tools-section {
        padding: var(--spacing-md);
    }
    
    .custom-tools-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }
}

@media (max-width: 768px) {
    .custom-tools-grid {
        grid-template-columns: 1fr;
    }
    
    .template-grid {
        grid-template-columns: 1fr;
    }
    
    .custom-tools-actions {
        flex-direction: column;
        align-items: stretch;
    }
    
    .tools-view-toggle {
        margin-left: 0;
        justify-content: center;
    }
    
    .tools-search-input {
        width: 100%;
        min-width: 0;
    }
    
    .modal-content {
        max-width: 100%;
        max-height: 100vh;
        border-radius: 0;
    }
    
    .tool-meta {
        flex-direction: column;
        gap: var(--spacing-xs);
    }
}

/* Scrollbar Styling */
.modal-body::-webkit-scrollbar,
.code-preview::-webkit-scrollbar,
#test-output::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

.modal-body::-webkit-scrollbar-track,
.code-preview::-webkit-scrollbar-track,
#test-output::-webkit-scrollbar-track {
    background: var(--dark-bg);
}

.modal-body::-webkit-scrollbar-thumb,
.code-preview::-webkit-scrollbar-thumb,
#test-output::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 4px;
}

.modal-body::-webkit-scrollbar-thumb:hover,
.code-preview::-webkit-scrollbar-thumb:hover,
#test-output::-webkit-scrollbar-thumb:hover {
    background: var(--text-secondary);
}
