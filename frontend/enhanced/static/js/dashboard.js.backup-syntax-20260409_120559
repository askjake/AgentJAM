        // Show custom tools section, hide regular settings
        if (customToolsSection) customToolsSection.style.display = 'block';
        if (settingsContent) settingsContent.style.display = 'none';
    } else {
        // Show regular settings, hide custom tools
        if (customToolsSection) customToolsSection.style.display = 'none';
        if (settingsContent) settingsContent.style.display = 'block';
        // Render settings for this tab
        renderSettings();
    }
}

function renderSettings() {
    const container = document.getElementById('settings-content');
    if (!container) return;
    
    const settings = settingsData[currentSettingsTab] || {};
    
    if (Object.keys(settings).length === 0) {
        container.innerHTML = `
            <div style="text-align: center; padding: 40px; color: #718096;">
                <i class="fas fa-cog" style="font-size: 48px; margin-bottom: 20px; opacity: 0.3;"></i>
                <p>No settings available for this category.</p>
            </div>
        `;
        return;
    }
    
    // Group settings by category
    const categories = {};
    Object.entries(settings).forEach(([key, setting]) => {
        const category = setting.category || 'General';
        if (!categories[category]) {
            categories[category] = [];
        }
        categories[category].push({ key, ...setting });
    });
    
    // Render grouped settings
    let html = '';
    Object.entries(categories).forEach(([category, items]) => {
        html += `
            <div class="settings-category">
                <h3 class="settings-category-title">
                    <i class="fas fa-folder"></i> ${category}
                </h3>
                <div class="settings-items">
        `;
        
        items.forEach(item => {
            html += renderSettingItem(item);
        });
        
        html += `
                </div>
            </div>
        `;
    });
    
    container.innerHTML = html;
    
    // Add event listeners to setting inputs
    container.querySelectorAll('.setting-input').forEach(input => {
        input.addEventListener('change', (e) => {
            const key = e.target.dataset.key;
            updateSettingValue(key, e.target.value, e.target.type);
        });
    });
}

function renderSettingItem(item) {
    const { key, value, description, type, sensitive, options, min, max } = item;
    
    let inputHtml = '';
    
    switch (type) {
        case 'boolean':
            inputHtml = `
                <label class="toggle-switch">
                    <input type="checkbox" class="setting-input" 
                           data-key="${key}" ${value ? 'checked' : ''}>
                    <span class="toggle-slider"></span>
                </label>
            `;
            break;
        
        case 'select':
            inputHtml = `
                <select class="setting-input" data-key="${key}">
                    ${options.map(opt => 
                        `<option value="${opt}" ${value === opt ? 'selected' : ''}>${opt}</option>`
                    ).join('')}
                </select>
            `;
            break;
        
        case 'integer':
        case 'number':
            inputHtml = `
                <input type="number" class="setting-input" 
                       data-key="${key}" value="${value}" 
                       ${min !== undefined ? `min="${min}"` : ''}
                       ${max !== undefined ? `max="${max}"` : ''}>
            `;
            break;
        
        case 'password':
            inputHtml = `
                <div style="display: flex; gap: 8px; align-items: center;">
                    <input type="password" class="setting-input" 
                           data-key="${key}" value="${value}" 
                           placeholder="Enter ${key}" 
                           style="flex: 1;">
                    <button class="btn-icon" onclick="togglePasswordVisibility(this)" title="Show/Hide">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            `;
            break;
        
        case 'url':
        case 'text':
        default:
            inputHtml = `
                <input type="${type === 'url' ? 'url' : 'text'}" 
                       class="setting-input" 
                       data-key="${key}" value="${value}" 
                       placeholder="Enter ${key}">
            `;
            break;
    }
    
    return `
        <div class="setting-item" data-key="${key}">
            <div class="setting-info">
                <label class="setting-label">
                    ${key}
                    ${sensitive ? '<i class="fas fa-lock" style="color: #f59e0b; margin-left: 4px;" title="Sensitive"></i>' : ''}
                </label>
                <p class="setting-description">${description}</p>
            </div>
            <div class="setting-control">
                ${inputHtml}
            </div>
        </div>
    `;
}

function updateSettingValue(key, value, inputType) {
    if (!settingsData[currentSettingsTab][key]) return;
    
    // Convert value based on type
    if (inputType === 'checkbox') {
        settingsData[currentSettingsTab][key].value = document.querySelector(`.setting-input[data-key="${key}"]`).checked;
    } else if (settingsData[currentSettingsTab][key].type === 'integer') {
        settingsData[currentSettingsTab][key].value = parseInt(value);
    } else if (settingsData[currentSettingsTab][key].type === 'number') {
        settingsData[currentSettingsTab][key].value = parseFloat(value);
    } else {
        settingsData[currentSettingsTab][key].value = value;
    }
    
    console.log(`Updated ${key} to:`, settingsData[currentSettingsTab][key].value);
}

async function saveAllSettings() {
    const saveBtn = document.getElementById('save-settings');
    const statusDiv = document.getElementById('settings-status');
    
    try {
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
        
        const response = await fetch('/api/settings', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(settingsData)
        });
        
        if (response.ok) {
            statusDiv.style.display = 'block';
            statusDiv.style.backgroundColor = '#10b981';
            statusDiv.innerHTML = '<i class="fas fa-check-circle"></i> Settings saved successfully';
            setTimeout(() => statusDiv.style.display = 'none', 3000);
            
            // Reload settings to confirm
            await loadSettingsFromBackend();
            renderSettings();
        } else {
            throw new Error('Failed to save settings');
        }
    } catch (error) {
        console.error('Error saving settings:', error);
        statusDiv.style.display = 'block';
        statusDiv.style.backgroundColor = '#ef4444';
        statusDiv.innerHTML = '<i class="fas fa-exclamation-circle"></i> Failed to save settings';
        setTimeout(() => statusDiv.style.display = 'none', 3000);
    } finally {
        saveBtn.disabled = false;
        saveBtn.innerHTML = '<i class="fas fa-save"></i> Save All Changes';
    }
}

function exportSettings() {
    const dataStr = JSON.stringify(settingsData, null, 2);
    const dataBlob = new Blob([dataStr], { type: 'application/json' });
    const url = URL.createObjectURL(dataBlob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `dishchat-settings-${new Date().toISOString().split('T')[0]}.json`;
    link.click();
    URL.revokeObjectURL(url);
}

function importSettings(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = (e) => {
        try {
            const imported = JSON.parse(e.target.result);
            settingsData = imported;
            renderSettings();
            
            const statusDiv = document.getElementById('settings-status');
            statusDiv.style.display = 'block';
            statusDiv.style.backgroundColor = '#10b981';
            statusDiv.innerHTML = '<i class="fas fa-check-circle"></i> Settings imported. Remember to save!';
            setTimeout(() => statusDiv.style.display = 'none', 3000);
        } catch (error) {
            console.error('Error importing settings:', error);
            alert('Invalid settings file');
        }
    };
    reader.readAsText(file);
}

function filterSettings(searchTerm) {
    const term = searchTerm.toLowerCase();
    document.querySelectorAll('.setting-item').forEach(item => {
        const key = item.dataset.key.toLowerCase();
        const label = item.querySelector('.setting-label').textContent.toLowerCase();
        const desc = item.querySelector('.setting-description').textContent.toLowerCase();
        
        if (key.includes(term) || label.includes(term) || desc.includes(term)) {
            item.style.display = 'flex';
        } else {
            item.style.display = 'none';
        }
    });
}

function togglePasswordVisibility(btn) {
    const input = btn.previousElementSibling;
    const icon = btn.querySelector('i');
    
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}

// Initialize settings when view switches to settings
const originalSwitchView = switchView;
switchView = function(viewName) {
    originalSwitchView(viewName);
    
    if (viewName === 'settings') {
        setTimeout(() => initializeSettings(), 100);
    }
};


