// Navigation
function initializeNavigation() {
    const navButtons = document.querySelectorAll('.nav-btn');
    
    navButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const view = btn.getAttribute('data-view');
            switchView(view);
            
            navButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        });
    });
}

function switchView(viewName) {
    console.log(`Switching to view: ${viewName}`);
    
    document.querySelectorAll('.content-view').forEach(view => {
        view.classList.remove('active');
    });
    
    const targetView = document.getElementById(`${viewName}-view`);
    if (targetView) {
        targetView.classList.add('active');
        state.currentView = viewName;
        
        // Load analytics charts when switching to analytics view
        if (viewName === 'analytics' && typeof loadAnalyticsCharts === 'function') {
            setTimeout(() => loadAnalyticsCharts(), 100);
        }
    }
}

// Chat functionality
function initializeChat() {
    const chatInput = document.getElementById('chat-input');
    const sendButton = document.getElementById('send-message');
    
    if (!chatInput || !sendButton) {
        console.error('Chat elements not found');
        return;
    }
    
    // Auto-resize textarea
    chatInput.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
    });
    
    // Send on Enter (not Shift+Enter)
    chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
    
    sendButton.addEventListener('click', sendMessage);
    
    // Quick actions
    document.querySelectorAll('.quick-action').forEach(btn => {
        btn.addEventListener('click', () => {
            const action = btn.getAttribute('data-action');
            handleQuickAction(action);
        });
    });
}

function sendMessage() {
    const input = document.getElementById('chat-input');
    const message = input.value.trim();
    
    if (!message && state.attachments.length === 0) return;
    
    console.log('Sending message:', message);
    console.log('Reasoning mode:', state.reasoningMode);
    console.log('Attachments:', state.attachments.length);
    
    // Add user message
    addMessageToChat('user', message, state.attachments);
    
    // Clear input and attachments
    input.value = '';
    input.style.height = 'auto';
    
    // Show typing indicator
    showTypingIndicator();
    
    // Prepare request payload
    const payload = {
        messages: [{ 
            role: 'user', 
            content: message 
        }],
        chat_id: state.currentChatId,
        reasoning_mode: state.reasoningMode
    };
    
    // Add attachments if any
    if (state.attachments.length > 0) {
        payload.attachments = state.attachments;
    }
    
    // Send to backend
    fetch(`${CONFIG.API_BASE_URL}/api/chat`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        hideTypingIndicator();
        
        // Handle response
        const response = data.response || data.content || 'No response';
        const toolCalls = data.tool_calls || [];
        const reasoning = data.reasoning || null;
        const artifacts = data.artifacts || [];
        
        // Show reasoning if in reasoning mode
        if (reasoning && state.reasoningMode) {
            addReasoningToChat(reasoning);
        }
        
        // Show tool calls if any
        if (toolCalls.length > 0) {
            addToolCallsToChat(toolCalls);
        }
        
        // Show main response
        addMessageToChat('assistant', response);
        
        // Show artifacts if any
        if (artifacts.length > 0) {
            addArtifactsToChat(artifacts);
        }
        
        state.stats.conversations++;
        state.stats.tools += toolCalls.length;
        updateStatsDisplay();
        
        // Clear attachments after successful send
        state.attachments = [];
        updateAttachmentsDisplay();
    })
    .catch(error => {
        hideTypingIndicator();
        console.error('Chat error:', error);
        addMessageToChat('assistant', `❌ Error: ${error.message}. Please check backend connection at ${CONFIG.API_BASE_URL}`);
    });
}

function addMessageToChat(sender, content, attachments = []) {
    const messagesContainer = document.getElementById('chat-messages');
    const welcomeMessage = messagesContainer.querySelector('.welcome-message');
    
    if (welcomeMessage) {
        welcomeMessage.style.display = 'none';
    }
    
    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${sender}-message`;
    messageDiv.style.cssText = `
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 15px;
        animation: slideIn 0.3s ease-out;
        ${sender === 'user' ? 'align-items: flex-end;' : 'align-items: flex-start;'}
    `;
    
    // Show attachments for user messages
    if (sender === 'user' && attachments.length > 0) {
        const attachmentsDiv = document.createElement('div');
        attachmentsDiv.className = 'message-attachments';
        attachmentsDiv.style.cssText = 'display: flex; gap: 5px; flex-wrap: wrap; max-width: 70%;';
        
        attachments.forEach(att => {
            const attBadge = document.createElement('span');
            attBadge.style.cssText = 'background: #e2e8f0; padding: 4px 8px; border-radius: 4px; font-size: 12px;';
            attBadge.innerHTML = `📎 ${att.name}`;
            attachmentsDiv.appendChild(attBadge);
        });
        
        messageDiv.appendChild(attachmentsDiv);
    }
    
    const bubble = document.createElement('div');
    bubble.className = 'message-bubble';
    bubble.style.cssText = `
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 12px;
        ${sender === 'user' 
            ? 'background: #667eea; color: white;' 
            : 'background: #f7fafc; color: #2d3748; border: 1px solid #e2e8f0;'}
        line-height: 1.5;
        white-space: pre-wrap;
        word-wrap: break-word;
    `;
    
    // Format markdown-like content
    bubble.innerHTML = formatMessageContent(content);
    
    messageDiv.appendChild(bubble);
    messagesContainer.appendChild(messageDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
    
    state.messages.push({ sender, content, attachments });
}

