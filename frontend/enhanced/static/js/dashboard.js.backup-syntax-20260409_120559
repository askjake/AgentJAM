/**
 * Send message with streaming support
 * Streams tokens from backend as they arrive
 */
function streamingFetch(payload) {
    if (FEATURES.STREAMING_DEBUG) {
        console.log('[Streaming] Starting stream with payload:', payload);
    }
    
    // Create placeholder message for streaming content
    const messageId = 'msg-' + Date.now();
    const placeholderDiv = createPlaceholderMessage('assistant', messageId);
    
    let accumulatedText = '';
    
    // Hide typing indicator (we'll show streaming indicator instead)
    hideTypingIndicator();
    
    fetch(`${CONFIG.API_BASE_URL}/api/chat/stream`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        
        function processStream({ done, value }) {
            if (done) {
                if (FEATURES.STREAMING_DEBUG) {
                    console.log('[Streaming] Stream complete');
                }
                finalizeMessage(messageId, accumulatedText);
                return;
            }
            
            // Decode chunk
            const chunk = decoder.decode(value, { stream: true });
            const lines = chunk.split('\n');
            
            for (const line of lines) {
                if (line.startsWith('data: ')) {
                    const dataStr = line.substring(6);
                    
                    if (dataStr === '[DONE]') {
                        if (FEATURES.STREAMING_DEBUG) {
                            console.log('[Streaming] Received [DONE]');
                        }
                        finalizeMessage(messageId, accumulatedText);
                        return;
                    }
                    
                    try {
                        const data = JSON.parse(dataStr);
                        
                        if (data.type === 'start') {
                            if (FEATURES.STREAMING_DEBUG) {
                                console.log('[Streaming] Stream started');
                            }
                        }
                        else if (data.type === 'token') {
                            // Append token to accumulated text
                            accumulatedText += data.content;
                            updateMessageContent(messageId, accumulatedText);
                            
                            if (FEATURES.STREAMING_DEBUG && accumulatedText.length % 50 === 0) {
                                console.log(`[Streaming] Accumulated ${accumulatedText.length} chars`);
                            }
                        }
                        else if (data.type === 'done') {
                            if (FEATURES.STREAMING_DEBUG) {
                                console.log('[Streaming] Done event received');
                            }
                            // Store chat_id if provided
                            if (data.chat_id && typeof state !== 'undefined') {
                                state.currentChatId = data.chat_id;
                            }
                        }
                        else if (data.type === 'error') {
                            console.error('[Streaming] Error:', data.error);
                            updateMessageContent(messageId, `❌ Error: ${data.error}`);
                            finalizeMessage(messageId, accumulatedText);
                            return;
                        }
                    } catch (e) {
                        if (FEATURES.STREAMING_DEBUG) {
                            console.error('[Streaming] Parse error:', e);
                        }
                    }
                }
            }
            
            // Read next chunk
            return reader.read().then(processStream);
        }
        
        return reader.read().then(processStream);
    })
    .catch(error => {
        console.error('[Streaming] Fetch error:', error);
        updateMessageContent(messageId, `❌ Error: ${error.message}`);
        finalizeMessage(messageId, accumulatedText);
    });
}

/**
 * Create a placeholder message element for streaming content
 */
function createPlaceholderMessage(sender, messageId) {
    const messagesContainer = document.getElementById('chat-messages');
    if (!messagesContainer) {
        console.error('[Streaming] Messages container not found');
        return null;
    }
    
    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${sender}-message streaming`;
    messageDiv.id = messageId;
    
    const contentDiv = document.createElement('div');
    contentDiv.className = 'message-content';
    contentDiv.textContent = '';  // Start empty
    
    messageDiv.appendChild(contentDiv);
    messagesContainer.appendChild(messageDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
    
    if (FEATURES.STREAMING_DEBUG) {
        console.log(`[Streaming] Created placeholder: ${messageId}`);
    }
    
    return messageDiv;
}

/**
 * Update message content during streaming
 */
function updateMessageContent(messageId, content) {
    const messageDiv = document.getElementById(messageId);
    if (messageDiv) {
        const contentDiv = messageDiv.querySelector('.message-content');
        if (contentDiv) {
            contentDiv.textContent = content;
            
            // Auto-scroll to bottom as content grows
            const messagesContainer = document.getElementById('chat-messages');
            if (messagesContainer) {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }
        }
    }
}

/**
 * Finalize message when streaming is complete
 */
function finalizeMessage(messageId, content) {
    const messageDiv = document.getElementById(messageId);
    if (messageDiv) {
        messageDiv.classList.remove('streaming');
        messageDiv.classList.add('complete');
        
        if (FEATURES.STREAMING_DEBUG) {
            console.log(`[Streaming] Finalized message: ${messageId}`);
        }
    }
    
    // Reload conversations to show the saved message
    if (typeof loadConversations === 'function') {
        loadConversations();
    }
}

