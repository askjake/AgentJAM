// Tool Testing Functionality
function initializeToolTests() {
    const testButtons = document.querySelectorAll('.btn-test-tool');
    const modal = document.getElementById('tool-test-modal');
    const closeButton = modal.querySelector('.modal-close');
    const executeButton = document.getElementById('execute-tool');
    
    testButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const toolName = btn.getAttribute('data-tool');
            openToolTestModal(toolName);
        });
    });
    
    closeButton.addEventListener('click', () => {
        modal.style.display = 'none';
    });
    
    window.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.style.display = 'none';
        }
    });
    
    executeButton.addEventListener('click', executeToolTest);
}

function openToolTestModal(toolName) {
    const modal = document.getElementById('tool-test-modal');
    const toolNameEl = document.getElementById('modal-tool-name');
    const parametersEl = document.getElementById('tool-parameters');
    const resultsEl = document.getElementById('tool-results');
    
    toolNameEl.textContent = toolName;
    resultsEl.textContent = 'No results yet...';
    
    // Get tool definition
    const toolDef = TOOL_DEFINITIONS[toolName];
    
    if (!toolDef) {
        parametersEl.innerHTML = '<p style="color: red;">Tool definition not found</p>';
        modal.style.display = 'block';
        return;
    }
    
    // Build parameter form
    let formHtml = '<div class="tool-params-form">';
    
    toolDef.params.forEach(param => {
        formHtml += `
            <div class="param-field" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px;">
                    ${param.name}${param.required ? ' <span style="color: red;">*</span>' : ''}
                </label>
        `;
        
        if (param.type === 'textarea') {
            formHtml += `
                <textarea 
                    name="${param.name}" 
                    placeholder="${param.placeholder || ''}"
                    style="width: 100%; min-height: 100px; padding: 8px; border: 1px solid #cbd5e0; border-radius: 4px; font-family: monospace;"
                    ${param.required ? 'required' : ''}
                >${param.default || ''}</textarea>
            `;
        } else if (param.type === 'select') {
            formHtml += `<select name="${param.name}" style="width: 100%; padding: 8px; border: 1px solid #cbd5e0; border-radius: 4px;" ${param.required ? 'required' : ''}>`;
            param.options.forEach(opt => {
                formHtml += `<option value="${opt}" ${opt === param.default ? 'selected' : ''}>${opt}</option>`;
            });
            formHtml += '</select>';
        } else {
            formHtml += `
                <input 
                    type="${param.type}" 
                    name="${param.name}" 
                    placeholder="${param.placeholder || ''}"
                    value="${param.default || ''}"
                    style="width: 100%; padding: 8px; border: 1px solid #cbd5e0; border-radius: 4px;"
                    ${param.required ? 'required' : ''}
                />
            `;
        }
        
        formHtml += '</div>';
    });
    
    formHtml += '</div>';
    
    parametersEl.innerHTML = formHtml;
    
    // Auto-fill chat_id if present
    const chatIdInput = parametersEl.querySelector('input[name="chat_id"]');
    if (chatIdInput && !chatIdInput.value) {
        chatIdInput.value = state.currentChatId;
    }
    
    modal.style.display = 'block';
}

function executeToolTest() {
    const modal = document.getElementById('tool-test-modal');
    const toolName = document.getElementById('modal-tool-name').textContent;
    const parametersEl = document.getElementById('tool-parameters');
    const resultsEl = document.getElementById('tool-results');
    const executeButton = document.getElementById('execute-tool');
    
    // Gather parameters
    const params = {};
    const inputs = parametersEl.querySelectorAll('input, textarea, select');
    
    inputs.forEach(input => {
        const value = input.value.trim();
        if (value) {
            // Convert to appropriate type
            if (input.type === 'number') {
                params[input.name] = parseFloat(value);
            } else if (input.name === 'serviceUids' && value.includes(',')) {
                params[input.name] = value.split(',').map(v => parseInt(v.trim()));
            } else {
                params[input.name] = value;
            }
        }
    });
    
    console.log('Executing tool:', toolName, 'with params:', params);
    
    // Show loading
    resultsEl.textContent = '⏳ Executing tool...';
    executeButton.disabled = true;
    
    // Call backend
    fetch(`${CONFIG.API_BASE_URL}/api/tools/${toolName}`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(params)
    })
    .then(response => {
        if (!response.ok) {
            return response.text().then(text => {
                throw new Error(`HTTP ${response.status}: ${text}`);
            });
        }
        return response.json();
    })
    .then(data => {
        resultsEl.textContent = JSON.stringify(data, null, 2);
        executeButton.disabled = false;
        
        // Update stats
        state.stats.tools++;
        updateStatsDisplay();
        
        // Add to activity log
        addActivityLog(toolName, 'success');
    })
    .catch(error => {
        console.error('Tool execution error:', error);
        resultsEl.textContent = `❌ Error:\n${error.message}`;
        resultsEl.style.color = 'red';
        executeButton.disabled = false;
        
        addActivityLog(toolName, 'error');
    });
}

// File Attachment
function initializeFileAttachment() {
    const attachButton = document.getElementById('attach-file');
    
    if (!attachButton) return;
    
    // Create hidden file input
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.multiple = true;
    fileInput.accept = CONFIG.SUPPORTED_FORMATS.map(f => `.${f}`).join(',');
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);
    
    attachButton.addEventListener('click', () => {
        fileInput.click();
    });
    
    fileInput.addEventListener('change', (e) => {
        const files = Array.from(e.target.files);
        handleFileSelection(files);
        fileInput.value = ''; // Reset
    });
    
    // Drag and drop
    const chatInput = document.getElementById('chat-input');
    const inputContainer = document.querySelector('.chat-input-container');
    
    inputContainer.addEventListener('dragover', (e) => {
        e.preventDefault();
        inputContainer.style.background = '#f0f4ff';
    });
    
    inputContainer.addEventListener('dragleave', () => {
        inputContainer.style.background = '';
    });
    
    inputContainer.addEventListener('drop', (e) => {
        e.preventDefault();
        inputContainer.style.background = '';
        
        const files = Array.from(e.dataTransfer.files);
        handleFileSelection(files);
    });
}

function handleFileSelection(files) {
    files.forEach(file => {
        // Validate size
        if (file.size > CONFIG.MAX_FILE_SIZE) {
            alert(`File ${file.name} is too large. Max size: 500MB`);
            return;
        }
        
        // Validate format
        const ext = file.name.split('.').pop().toLowerCase();
        if (!CONFIG.SUPPORTED_FORMATS.includes(ext)) {
            alert(`File ${file.name} format not supported. Supported: ${CONFIG.SUPPORTED_FORMATS.join(', ')}`);
            return;
        }
        
        // Read file content
        const reader = new FileReader();
        reader.onload = (e) => {
            const attachment = {
                name: file.name,
                type: file.type || 'text/plain',
                size: file.size,
                content: e.target.result, isImage: file.type.startsWith('image/'), isVideo: file.type.startsWith('video/')
            };
            
            state.attachments.push(attachment);
            updateAttachmentsDisplay();
        };
        if (file.type.startsWith('image/') || file.type.startsWith('video/')) { reader.readAsDataURL(file); } else { reader.readAsText(file); }
    });
}

function updateAttachmentsDisplay() {
    const inputContainer = document.querySelector('.input-wrapper');
    let attachmentsDisplay = inputContainer.querySelector('.attachments-display');
    
    if (!attachmentsDisplay) {
        attachmentsDisplay = document.createElement('div');
        attachmentsDisplay.className = 'attachments-display';
        attachmentsDisplay.style.cssText = 'display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 8px;';
        inputContainer.insertBefore(attachmentsDisplay, inputContainer.firstChild);
    }
    
    if (state.attachments.length === 0) {
        attachmentsDisplay.style.display = 'none';
