// Store original sendMessage if it exists
if (typeof sendMessage !== 'undefined') {
    window.originalSendMessage = sendMessage;
    
    // Override sendMessage to add streaming support
    sendMessage = function() {
        const input = document.getElementById('chat-input');
        if (!input) return;
        
        const message = input.value.trim();
        
        if (!message && (!state || state.attachments.length === 0)) return;
        
        if (FEATURES.STREAMING_DEBUG) {
            console.log('[Streaming] sendMessage called');
            console.log('[Streaming] Streaming enabled:', FEATURES.STREAMING_ENABLED);
        }
        
        // Add user message to UI
        if (typeof addMessageToChat === 'function') {
            addMessageToChat('user', message, state ? state.attachments : []);
        }
        
        // Clear input and attachments
        input.value = '';
        input.style.height = 'auto';
        
        // Prepare request payload
        const payload = {
            messages: [{ role: 'user', content: message }],
            chat_id: state ? state.currentChatId : null,
            reasoning_mode: state ? state.reasoningMode : false,
            attachments: state ? state.attachments : []
        };
        
        // Use streaming or traditional based on feature flag
        if (FEATURES.STREAMING_ENABLED) {
            if (FEATURES.STREAMING_DEBUG) {
                console.log('[Streaming] Using streaming fetch');
            }
            streamingFetch(payload);
        } else {
            if (FEATURES.STREAMING_DEBUG) {
                console.log('[Streaming] Using traditional fetch');
            }
            // Call original implementation
            if (typeof window.originalSendMessage === 'function') {
                window.originalSendMessage();
            }
        }
        
        // Clear attachments
        if (state) {
            state.attachments = [];
            if (typeof updateAttachmentsDisplay === 'function') {
                updateAttachmentsDisplay();
            }
        }
    };
    
    console.log('[Streaming] sendMessage function enhanced with streaming support');
}

