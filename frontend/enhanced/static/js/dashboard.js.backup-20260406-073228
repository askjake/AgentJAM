function renderSettings(settings) {
    const activeTab = document.querySelector(".settings-tab.active");
    if (!activeTab) return;
    const tab = activeTab.dataset.tab;
    const content = document.getElementById("settings-content");
    if (!content) return;
    
    let html = "";
    if (tab === "backend") {
        html = renderBackendSettings(settings.BACKEND_CONFIGURATION || {});
    } else if (tab === "frontend") {
        html = renderFrontendSettings();
    } else {
        html = renderCustomToolsSettings();
    }
    content.innerHTML = html;
    attachSettingsListeners();
}

function renderBackendSettings(backendConfig) {
    let html = "<div class=\"settings-sections\">";
    for (const [categoryName, category] of Object.entries(backendConfig)) {
        html += "<div class=\"settings-section\"><h3>" + categoryName + "</h3>";
        html += "<div class=\"settings-grid\">";
        for (const [key, config] of Object.entries(category)) {
            html += "<div class=\"setting-item\">";
            html += "<div class=\"setting-label\"><label>" + key.replace(/_/g, " ") + "</label></div>";
            html += "<div class=\"setting-description\">" + (config.description || "") + "</div>";
            html += "<div class=\"setting-input\">" + renderSettingInput(key, config) + "</div>";
            html += "</div>";
        }
        html += "</div></div>";
    }
    html += "</div>";
    return html;
}

function renderSettingInput(key, config) {
    const value = config.value;
    const type = config.type;
    if (type === "boolean") {
        return "<label class=\"toggle-switch\"><input type=\"checkbox\" data-setting=\"" + key + "\" " + (value ? "checked" : "") + "><span class=\"toggle-slider\"></span></label>";
    } else if (type === "integer" || type === "number") {
        return "<input type=\"number\" data-setting=\"" + key + "\" value=\"" + value + "\" class=\"setting-input-field\">";
    } else {
        return "<input type=\"text\" data-setting=\"" + key + "\" value=\"" + value + "\" class=\"setting-input-field\">";
    }
}

function renderFrontendSettings() {
    return "<div class=\"settings-sections\"><div class=\"settings-section\"><h3>Frontend Settings</h3><p>Frontend configuration coming soon...</p></div></div>";
}

function renderCustomToolsSettings() {
    return "<div class=\"settings-sections\"><div class=\"settings-section\"><h3>Custom Tools</h3><p>Custom tool configuration coming soon...</p></div></div>";
}

function attachSettingsListeners() {
    document.querySelectorAll(".settings-tab").forEach(tab => {
        tab.addEventListener("click", () => {
            document.querySelectorAll(".settings-tab").forEach(t => t.classList.remove("active"));
            tab.classList.add("active");
            renderSettings(currentSettings);
        });
    });
    
    const saveBtn = document.getElementById("save-settings");
    if (saveBtn) {
        saveBtn.addEventListener("click", saveSettings);
    }
}

async function saveSettings() {
    const updates = {};
    document.querySelectorAll("[data-setting]").forEach(input => {
        const key = input.dataset.setting;
        updates[key] = input.type === "checkbox" ? input.checked : input.value;
    });
    
    try {
        const response = await fetch(CONFIG.API_BASE_URL + "/api/settings", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(updates)
        });
        if (response.ok) {
            showToast("Settings saved", "success");
            loadSettings();
        }
    } catch (error) {
        showToast("Failed to save", "error");
    }
}

